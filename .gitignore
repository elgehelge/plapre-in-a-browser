# Node / web
node_modules/
web/dist/
web/.vite/
*.log

# LICENSE/NOTICE are copied into web/ at publish time (prepack); the sources of
# truth live at the repo root.
web/LICENSE
web/NOTICE

# Python / conversion
conversion/.venv/
__pycache__/
*.pyc
conversion/build/

# Model artifacts (large / generated; not committed — see conversion/README.md).
# Recursive so model subdirs (lm/, lm_toy/, …) are covered too.
web/public/models/**/*.onnx
web/public/models/**/*.onnx_data
web/public/models/**/*.onnx.data
web/public/models/**/*.bin
artifacts/
*.safetensors
*.gguf

# Generated artifact metadata / goldens (regenerable via conversion/).
web/public/models/phase0_golden.json
web/public/models/lm/meta.json
web/public/models/speaker_proj.json
web/public/models/lm_toy/
web/public/models/phase1_toy_golden.json
web/public/models/clone_golden.json

# Gated-repo files copied locally (regenerable via fetch_tokenizer.py /
# precompute_speakers.py; derived from the gated Plapre weights).
web/public/models/tokenizer.json
web/public/models/config.json
web/public/models/speakers.json

# Golden fixtures derived from the gated weights (regenerable via
# smoke_reference.py); audio + token oracles.
conversion/golden/

# OS
.DS_Store

# Local Cursor IDE / agent settings
.cursor/
